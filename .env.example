# Alex — environment variables
# Copy to .env and fill in your values (from Terraform outputs where noted)

AWS_ACCOUNT_ID=123456789012
DEFAULT_AWS_REGION=us-east-1

# Embeddings (terraform/2_sagemaker)
SAGEMAKER_ENDPOINT=alex-embedding-endpoint

# Ingest / vector store (terraform/3_ingestion)
VECTOR_BUCKET=alex-vectors-123456789012
ALEX_API_ENDPOINT=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod/ingest
ALEX_API_KEY=your-api-key-here

# Researcher (optional)
OPENAI_API_KEY=sk-...

# SEC 10-K RAG (backend/sec_rag — Chroma locally, S3 Vectors on Lambda)
# auto | chroma | s3
SEC_RAG_MODE=auto

# Database (terraform/5_database)
AURORA_CLUSTER_ARN=arn:aws:rds:us-east-1:123456789012:cluster:alex-aurora-cluster
AURORA_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:alex-aurora-credentials-xxxxx
AURORA_DATABASE=alex

# Agents (terraform/6_agents)
BEDROCK_MODEL_ID=us.amazon.nova-pro-v1:0
BEDROCK_REGION=us-west-2
SQS_QUEUE_URL=
POLYGON_API_KEY=your_polygon_api_key_here
POLYGON_PLAN=free

# Frontend / API (Clerk + CORS)
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-instance.clerk.accounts.dev
FRONTEND_URL=http://localhost:3000
CLOUDFRONT_URL=
